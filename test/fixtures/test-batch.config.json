{
  "name": "test-batch",
  "columnMappings": {
    "apo_list_*.csv": {
      "顧客名": "customer_name",
      "電話番号": "phone",
      "メールアドレス": "email",
      "会社名": "company_name",
      "住所": "address",
      "担当者名": "staff",
      "商材": "product",
      "契約日": "contract_date",
      "対応日": "activity_date",
      "対応種別": "activity_type",
      "メモ": "note"
    },
    "product_*_customers.csv": {
      "氏名": "customer_name",
      "TEL": "phone",
      "Eメール": "email",
      "法人名": "company_name",
      "店舗名": "store_name",
      "所在地": "address",
      "サービス": "product",
      "契約開始日": "contract_date",
      "金額": "amount",
      "最終対応日": "activity_date",
      "対応内容": "activity_type",
      "備考": "note"
    }
  },
  "canonicalFields": {
    "phone": ["phone", "tel", "電話番号", "TEL", "携帯番号"],
    "email": ["email", "mail", "メールアドレス", "Eメール"],
    "name": ["name", "customer_name", "氏名", "名前", "担当者名", "顧客名"],
    "companyName": ["company_name", "company", "会社名", "法人名"],
    "storeName": ["store_name", "store", "店舗名"],
    "address": ["address", "住所", "所在地"]
  },
  "classification": {
    "customerFields": ["company_name", "customer_name", "phone", "email", "address", "store_name"],
    "dealFields": ["product", "service", "contract_date"],
    "transactionFields": ["amount", "payment_date", "invoice_number"],
    "activityFields": ["activity_date", "activity_type", "note"],
    "minFieldsForClassification": 2,
    "priorityOrder": ["customer", "deal", "activity", "transaction"]
  },
  "chunkSize": 100,
  "outputDir": "./test/output-batch"
}
