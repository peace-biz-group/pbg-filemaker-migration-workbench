{
  "name": "sample-project",
  "inputs": [
    { "path": "./data/apo_list_2024.csv", "label": "アポリスト2024", "mode": "mainline" },
    { "path": "./data/product_a_customers.csv", "label": "商材A顧客管理", "mode": "mainline" },
    { "path": "./data/legacy_export_2021.csv", "label": "旧CSVアーカイブ", "mode": "archive" }
  ],
  "columnMappings": {
    "apo_list_*.csv": {
      "顧客名": "customer_name",
      "電話番号": "phone",
      "メールアドレス": "email",
      "会社名": "company_name",
      "住所": "address",
      "担当者名": "staff",
      "商材": "product",
      "契約日": "contract_date",
      "対応日": "activity_date",
      "対応種別": "activity_type",
      "メモ": "note"
    },
    "product_*_customers.csv": {
      "氏名": "customer_name",
      "TEL": "phone",
      "Eメール": "email",
      "法人名": "company_name",
      "店舗名": "store_name",
      "所在地": "address",
      "サービス": "product",
      "契約開始日": "contract_date",
      "金額": "amount",
      "最終対応日": "activity_date",
      "対応内容": "activity_type",
      "備考": "note"
    }
  },
  "canonicalFields": {
    "phone": ["phone", "tel", "電話番号", "TEL", "携帯番号"],
    "email": ["email", "mail", "メールアドレス", "Eメール"],
    "name": ["name", "customer_name", "氏名", "名前", "担当者名", "顧客名"],
    "companyName": ["company_name", "company", "会社名", "法人名"],
    "storeName": ["store_name", "store", "店舗名"],
    "address": ["address", "住所", "所在地"]
  },
  "normalization": {
    "trimWhitespace": true,
    "normalizeFullWidthToHalfWidth": true,
    "normalizePhone": true,
    "lowercaseEmail": true,
    "normalizeDates": true,
    "cleanWhitespaceAndNewlines": true,
    "normalizeCompanyName": true,
    "normalizeAddress": true,
    "normalizeStoreName": true
  },
  "duplicateDetection": {
    "enablePhoneMatch": true,
    "enableEmailMatch": true,
    "enableNameCompanyMatch": true,
    "enableNameAddressMatch": true,
    "useNormalizedKeys": true
  },
  "classification": {
    "customerFields": ["company_name", "customer_name", "phone", "email", "address", "store_name"],
    "dealFields": ["product", "service", "contract_date"],
    "transactionFields": ["amount", "payment_date", "invoice_number"],
    "activityFields": ["activity_date", "activity_type", "note"],
    "minFieldsForClassification": 2,
    "priorityOrder": ["customer", "deal", "activity", "transaction"]
  },
  "diffKeys": {
    "apo_list_*.csv": {
      "recordIdField": "fm_record_id",
      "updatedAtField": "updated_at",
      "naturalKeyFields": ["customer_name", "phone", "activity_date"],
      "fingerprintFields": ["customer_name", "phone", "activity_date", "activity_type", "note"],
      "mode": "mainline"
    },
    "customer-management*.csv": {
      "recordIdField": "fm_record_id",
      "updatedAtField": "updated_at",
      "naturalKeyFields": ["customer_name", "company_name", "phone"],
      "fingerprintFields": ["customer_name", "company_name", "phone", "email", "address"],
      "mode": "mainline"
    },
    "call-history*.csv": {
      "recordIdField": "fm_record_id",
      "updatedAtField": "updated_at",
      "naturalKeyFields": ["customer_name", "activity_date", "activity_type"],
      "fingerprintFields": ["customer_name", "activity_date", "activity_type", "note"],
      "mode": "mainline"
    },
    "visit-history*.csv": {
      "recordIdField": "fm_record_id",
      "updatedAtField": "updated_at",
      "naturalKeyFields": ["customer_name", "activity_date", "staff"],
      "fingerprintFields": ["customer_name", "activity_date", "staff", "note"],
      "mode": "mainline"
    },
    "followup-history*.csv": {
      "recordIdField": "fm_record_id",
      "updatedAtField": "updated_at",
      "naturalKeyFields": ["customer_name", "activity_date", "product"],
      "fingerprintFields": ["customer_name", "activity_date", "product", "note"],
      "mode": "mainline"
    }
  },
  "identityStrategies": {
    "apo_list_*.csv": {
      "recordFamily": "apo_list",
      "nativeIdField": "fm_record_id",
      "deterministicFields": ["customer_name", "phone", "activity_date"],
      "entityMatchFields": ["customer_name", "phone", "company_name"],
      "mainlineFingerprintFields": ["customer_name", "phone", "activity_date", "activity_type", "note"]
    },
    "customer-management*.csv": {
      "recordFamily": "customer_master_like",
      "nativeIdField": "fm_record_id",
      "deterministicFields": ["customer_name", "company_name", "phone"],
      "entityMatchFields": ["customer_name", "company_name", "phone", "email"],
      "mainlineFingerprintFields": ["customer_name", "company_name", "phone", "email", "address"]
    },
    "call-history*.csv": {
      "recordFamily": "call_activity",
      "nativeIdField": "fm_record_id",
      "deterministicFields": ["customer_name", "activity_date", "operator", "result_code", "activity_type"],
      "entityMatchFields": ["customer_name", "phone"],
      "mainlineFingerprintFields": ["customer_name", "activity_date", "operator", "result_code", "activity_type", "note"]
    },
    "visit-history*.csv": {
      "recordFamily": "visit_activity",
      "nativeIdField": "fm_record_id",
      "deterministicFields": ["customer_name", "activity_date", "operator", "visit_type", "result_code", "staff"],
      "entityMatchFields": ["customer_name", "phone"],
      "mainlineFingerprintFields": ["customer_name", "activity_date", "operator", "visit_type", "result_code", "staff", "note"]
    },
    "followup-history*.csv": {
      "recordFamily": "retry_followup",
      "nativeIdField": "fm_record_id",
      "deterministicFields": ["customer_name", "scheduled_followup_date", "retry_date", "operator", "retry_status", "product"],
      "entityMatchFields": ["customer_name", "phone", "product"],
      "mainlineFingerprintFields": ["customer_name", "scheduled_followup_date", "retry_date", "operator", "retry_status", "outcome", "product", "note"]
    }
  },
  "semanticOwnerRules": {
    "enforceCustomerFamilyOwner": true
  },
  "mainlineEligibilityRules": {
    "disallowFallback": true,
    "disallowCustomerOwnerUnknown": true,
    "disallowCustomerOwnerHybrid": true
  },
  "chunkSize": 5000,
  "outputDir": "./output"
}
